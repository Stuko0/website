---
import AnimatedButton from "../ui/AnimatedButton.astro";

const slides = [
  {
    title: "Lorem Impum Dolor sit Ament",
    subtitle: "Explore Exotic Destinations",
    description: "Embark on an adventure to the world's most beautiful and exotic locations. Discover breathtaking landscapes and vibrant cultures with our exclusive travel packages.",
    cta: "PLAN YOUR TRIP",
    bgClass: "https://images.pexels.com/photos/50707/cocoa-man-colombia-peasant-50707.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
  },
  {
    title: "Lorem Impum Dolor sit Ament",
    subtitle: "Tropical Getaways",
    description: "Enjoy our limited-time summer deals to paradise islands with crystal clear waters and white sandy beaches.",
    cta: "BOOK NOW",
    bgClass: "https://images.pexels.com/photos/8900912/pexels-photo-8900912.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
  },
  {
    title: "Lorem Impum Dolor sit Ament",
    subtitle: "Ski Resort Packages",
    description: "Experience the magic of winter with our all-inclusive ski resort packages in the Alps and Rockies.",
    cta: "EXPLORE DEALS",
    bgClass: "https://images.pexels.com/photos/6420910/pexels-photo-6420910.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1"
  }
];
---

<section class="relative h-[600px] overflow-hidden" id="hero-carousel">
  {slides.map((slide, index) => (
    <div 
      class={`absolute inset-0 flex items-center justify-center transition-opacity duration-700 ${
        index === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'
      }`}
      data-slide
    >
    <div 
          class="absolute inset-0 bg-cover bg-center"
          style={`background-image: url('${slide.bgClass}')`}
        ></div>
        <div class="absolute inset-0 bg-black/40"></div>
      <div class="container mx-auto px-6 text-white text-center relative z-10">
        <h2 class="text-2xl md:text-3xl font-bold mb-4 animate-fadeIn">{slide.title}</h2>
        <h3 class="text-4xl md:text-5xl font-bold mb-6 animate-fadeIn">{slide.subtitle}</h3>
        <p class="text-xl mb-8 max-w-2xl mx-auto animate-fadeIn">{slide.description}</p>
        <AnimatedButton>{slide.cta}</AnimatedButton>
      </div>
    </div>
  ))}

  <div class="absolute bottom-8 left-0 right-0 flex justify-center gap-2">
    {slides.map((_, index) => (
      <button
        onclick={`changeSlide(${index})`}
        class={`w-3 h-3 rounded-full transition-all ${index === 0 ? 'bg-white w-6' : 'bg-white/50'}`}
        aria-label={`Go to slide ${index + 1}`}
        data-indicator
      />
    ))}
  </div>
</section>

<style is:global>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 1s ease-out;
  }
</style>

<script is:inline>
  let currentSlide = 0;
  const slides = document.querySelectorAll('[data-slide]');
  const indicators = document.querySelectorAll('[data-indicator]');
  let intervalId;

  function changeSlide(index) {
    currentSlide = index;
    updateCarousel();
    resetInterval();
  }

  function updateCarousel() {
    slides.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === currentSlide);
      slide.classList.toggle('opacity-0', i !== currentSlide);
      slide.classList.toggle('pointer-events-none', i !== currentSlide);
    });

    indicators.forEach((indicator, i) => {
      indicator.classList.toggle('bg-white', i === currentSlide);
      indicator.classList.toggle('bg-white/50', i !== currentSlide);
      indicator.classList.toggle('w-6', i === currentSlide);
      indicator.classList.toggle('w-3', i !== currentSlide);
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % slides.length;
    updateCarousel();
  }

  function resetInterval() {
    clearInterval(intervalId);
    intervalId = setInterval(nextSlide, 5000);
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateCarousel();
    intervalId = setInterval(nextSlide, 5000);
    
    const carousel = document.getElementById('hero-carousel');
    carousel.addEventListener('mouseenter', () => clearInterval(intervalId));
    carousel.addEventListener('mouseleave', resetInterval);
  });
</script>