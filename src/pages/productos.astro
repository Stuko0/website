---
import PublicLayout from "../layouts/PublicLayout.astro"
import ProductCard from "../components/ui/ProductCard.astro"
import { getCollection } from "astro:content"

const allProducts = await getCollection("products")
const products = allProducts.filter(p => p.data.visible).map(p => ({
  id: p.id,
  name: p.data.name,
  slug: p.data.slug,
  price: p.data.price,
  unit: "unidad",
  category: p.data.category,
  imageUrl: p.data.image || "",
  imageHover: p.data.image || "",
}))

const categories = ["Todos", "Chocolate", "Cacao en polvo", "Manteca de cacao", "Nibs", "Bombones"]
---

<PublicLayout title="Productos">
  <div class="pt-24 pb-8 bg-primary">
    <div class="container mx-auto px-4">
      <h1 class="font-heading text-5xl text-accent mb-2">Nuestros Productos</h1>
      <p class="text-cream/80 text-lg">Cacao de la más alta calidad, directamente del productor a tu mesa.</p>
    </div>
  </div>

  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar: categorías -->
      <aside class="w-full lg:w-64 shrink-0">
        <h3 class="text-xl font-semibold text-heading mb-4">Categorías</h3>
        <ul class="space-y-2">
          {categories.map(cat => (
            <li>
              <a
                href={cat === "Todos" ? "/productos" : `/productos?categoria=${cat.toLowerCase().replace(/\s+/g, '-')}`}
                class="block px-4 py-2 rounded text-muted hover:bg-accent/20 hover:text-primary transition-colors"
              >
                {cat}
              </a>
            </li>
          ))}
        </ul>
      </aside>

      <!-- Grid de productos -->
      <main class="flex-1">
        <div class="flex justify-between items-center mb-6">
          <p class="text-muted">{products.length} producto(s)</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {products.map(p => (
            <ProductCard product={p} />
          ))}
        </div>

        <!-- Paginación placeholder -->
        <div class="flex justify-center mt-12 gap-2">
          <span class="w-10 h-10 flex items-center justify-center rounded bg-accent text-primary font-semibold">1</span>
          <span class="w-10 h-10 flex items-center justify-center rounded bg-border/50 text-muted hover:bg-accent/30 cursor-pointer">2</span>
          <span class="w-10 h-10 flex items-center justify-center rounded bg-border/50 text-muted hover:bg-accent/30 cursor-pointer">3</span>
        </div>
      </main>
    </div>
  </div>
</PublicLayout>
