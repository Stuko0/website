---
import PublicLayout from "../layouts/PublicLayout.astro"
import { Icon } from "astro-icon/components"
---

<PublicLayout title="Checkout">
  <div class="bg-primary pt-24 pb-4">
    <div class="container mx-auto px-4">
      <nav class="text-sm text-cream/70 mb-2">
        <a href="/" class="hover:text-accent">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/carrito" class="hover:text-accent">Carrito</a>
        <span class="mx-2">/</span>
        <span class="text-cream">Checkout</span>
      </nav>
      <h1 class="font-heading text-4xl text-accent">Checkout</h1>
    </div>
  </div>

  <div class="container mx-auto px-4 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Formulario -->
      <div class="flex-1 max-w-2xl">
        <!-- Información de envío -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-heading mb-4 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-accent text-primary flex items-center justify-center text-sm font-bold">1</span>
            Información de Envío
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold text-muted mb-1">Nombre completo</label>
              <input type="text" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="Juan Pérez" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold text-muted mb-1">Email</label>
              <input type="email" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="correo@ejemplo.com" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold text-muted mb-1">Teléfono</label>
              <input type="tel" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="+591 70000000" />
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold text-muted mb-1">Dirección</label>
              <input type="text" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="Calle y número" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-muted mb-1">Ciudad</label>
              <input type="text" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="La Paz" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-muted mb-1">Código Postal</label>
              <input type="text" class="w-full px-4 py-2 border-2 border-border rounded focus:border-accent focus:outline-none transition-colors" placeholder="0000" />
            </div>
          </div>
        </div>

        <!-- Método de envío -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-heading mb-4 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-accent text-primary flex items-center justify-center text-sm font-bold">2</span>
            Método de Envío
          </h2>
          <label class="flex items-center gap-3 p-4 border-2 border-accent rounded-lg cursor-pointer mb-2">
            <input type="radio" name="envio" checked class="accent-primary" />
            <div>
              <p class="font-semibold text-primary">Envío Estándar</p>
              <p class="text-sm text-muted">Entrega en 5-7 días hábiles</p>
            </div>
            <span class="ml-auto font-semibold">Bs 15.00</span>
          </label>
          <label class="flex items-center gap-3 p-4 border-2 border-border rounded-lg cursor-pointer hover:border-accent transition-colors">
            <input type="radio" name="envio" class="accent-primary" />
            <div>
              <p class="font-semibold text-primary">Envío Express</p>
              <p class="text-sm text-muted">Entrega en 1-2 días hábiles</p>
            </div>
            <span class="ml-auto font-semibold">Bs 35.00</span>
          </label>
        </div>

        <!-- Método de pago -->
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-heading mb-4 flex items-center gap-2">
            <span class="w-8 h-8 rounded-full bg-accent text-primary flex items-center justify-center text-sm font-bold">3</span>
            Método de Pago
          </h2>
          <label class="flex items-center gap-3 p-4 border-2 border-accent rounded-lg cursor-pointer mb-2">
            <input type="radio" name="pago" checked class="accent-primary" />
            <Icon name="mdi:bank" class="text-2xl text-primary" />
            <div>
              <p class="font-semibold text-primary">Transferencia Bancaria</p>
              <p class="text-sm text-muted">Transferencia a cuenta bancaria</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-4 border-2 border-border rounded-lg cursor-pointer hover:border-accent transition-colors mb-2">
            <input type="radio" name="pago" class="accent-primary" />
            <Icon name="mdi:credit-card" class="text-2xl text-primary" />
            <div>
              <p class="font-semibold text-primary">Tarjeta de Crédito/Débito</p>
              <p class="text-sm text-muted">Visa, Mastercard, American Express</p>
            </div>
          </label>
          <label class="flex items-center gap-3 p-4 border-2 border-border rounded-lg cursor-pointer hover:border-accent transition-colors">
            <input type="radio" name="pago" class="accent-primary" />
            <Icon name="mdi:qrcode" class="text-2xl text-primary" />
            <div>
              <p class="font-semibold text-primary">QR Payment</p>
              <p class="text-sm text-muted">Paga con tu aplicación móvil</p>
            </div>
          </label>
        </div>

        <button class="w-full bg-primary text-cream py-4 font-bold text-lg uppercase tracking-wider hover:bg-primary-light transition-colors">
          Confirmar Pedido
        </button>
      </div>

      <!-- Resumen lateral -->
      <aside class="w-full lg:w-80 shrink-0">
        <div class="bg-cream border-2 border-border rounded-lg p-6 sticky top-28">
          <h3 class="text-xl font-semibold text-heading mb-4">Tu Pedido</h3>
          <div class="space-y-3 pb-4 border-b border-border">
            <div class="flex justify-between text-sm">
              <span>Chocolate Amargo 70% × 2</span>
              <span>Bs 70.00</span>
            </div>
            <div class="flex justify-between text-sm">
              <span>Bombones Rellenos × 1</span>
              <span>Bs 65.00</span>
            </div>
          </div>
          <div class="space-y-3 pt-4 text-muted">
            <div class="flex justify-between">
              <span>Subtotal</span>
              <span>Bs 135.00</span>
            </div>
            <div class="flex justify-between">
              <span>Envío</span>
              <span>Bs 15.00</span>
            </div>
            <div class="border-t border-border pt-3 flex justify-between font-bold text-lg text-body">
              <span>Total</span>
              <span>Bs 150.00</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</PublicLayout>
